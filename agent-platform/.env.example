# AI Agent Platform Configuration
# Copy this to .env and customize

# ── Ollama (LLM) ──
AGENT_OLLAMA_BASE_URL=http://ollama:11434
AGENT_OLLAMA_MODEL=llama3.1:8b
AGENT_OLLAMA_TIMEOUT=120

# ── Browser ──
AGENT_BROWSER_HEADLESS=true
AGENT_BROWSER_VIEWPORT_WIDTH=1280
AGENT_BROWSER_VIEWPORT_HEIGHT=720
AGENT_BROWSER_TIMEOUT=30000

# ── Desktop ──
AGENT_VNC_HOST=desktop
AGENT_VNC_PORT=5900
AGENT_NOVNC_PORT=6080
AGENT_DESKTOP_RESOLUTION=1920x1080

# ── Vault ──
AGENT_VAULT_DB_PATH=/data/vault.db
AGENT_VAULT_KEY_PATH=/data/vault.key

# ── Streaming ──
AGENT_STREAM_FPS=10
AGENT_STREAM_QUALITY=60

# ── API ──
AGENT_API_HOST=0.0.0.0
AGENT_API_PORT=8000
AGENT_DEBUG=false

# ── Alternative LLM models ──
# AGENT_OLLAMA_MODEL=qwen2.5-coder:7b
# AGENT_OLLAMA_MODEL=llama3.1:70b
# AGENT_OLLAMA_MODEL=codellama:13b
